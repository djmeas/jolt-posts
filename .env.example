# Session encryption (required for auth). Use 32+ characters.
NUXT_SESSION_PASSWORD=your-secret-session-password-at-least-32-characters

# Optional: set to false only if the app is served over plain HTTP (e.g. http://IP:port without TLS).
# Default is true; browsers require HTTPS (or localhost) for Secure session cookies.
# NUXT_SESSION_COOKIE_SECURE=false

# Admin password for /admin/login
NUXT_ADMIN_PASSWORD=your-admin-password

# Display name shown on posts (defaults to "Jolt Posts")
NUXT_ADMIN_DISPLAY_NAME=Jolt Posts
